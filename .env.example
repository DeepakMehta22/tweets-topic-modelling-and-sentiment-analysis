# Copy this file to ".env" and fill in your own values.
# Never commit the real ".env" file — it's already excluded in .gitignore.

# Twitter API v1.1 (developer.twitter.com) — used by tweepy for collect_tweets()
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# Twitter API v2 bearer token (twarc2) — used for daily_hourly_trend_last7days()
TWITTER_BEARER_TOKEN=
